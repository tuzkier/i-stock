{
  "_comment": "将此文件复制为 config.json 并填入实际值。支持多个 YAPI 实例，每个实例可配置多个项目。",
  "providers": [
    {
      "name": "my-yapi",
      "type": "yapi",
      "base_url": "https://yapi.example.com",
      "projects": [
        {
          "name": "项目显示名称",
          "alias": "project-alias",
          "token": "your-project-token-here"
        },
        {
          "name": "另一个项目",
          "alias": "another-project",
          "token": "another-token-here"
        }
      ]
    },
    {
      "name": "second-yapi-instance",
      "type": "yapi",
      "base_url": "https://yapi2.example.com",
      "projects": [
        {
          "name": "其他团队项目",
          "alias": "other-team-project",
          "token": "token-here"
        }
      ]
    }
  ]
}
