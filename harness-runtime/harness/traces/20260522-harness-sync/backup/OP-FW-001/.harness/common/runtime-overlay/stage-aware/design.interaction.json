{
  "_comment": "Stage-4 M1.3 + 偏离修正1 (2026-05-15): design+interaction stage overlay (H4 naming). When stage='interaction', merges into settings.json. Visual-interaction-manifest direct write is denied — manifest must come from `harness evidence visual manifest` CLI. WebFetch/WebSearch are routed through ask channel since visual evidence collection requires user authorization. Cross-lane deny added (偏离修正1) to mirror solution / technical_analysis overlays — when in interaction lane, writes to solution.md / tech-design.md / *.contract.yaml of other lanes are physically blocked.",
  "permissions": {
    "deny": [
      "Edit(harness-runtime/harness/mission-status.yaml)",
      "Edit(harness-runtime/harness/work-graph/**)",
      "Write(**/visual-interaction-manifest.json)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Write(harness-runtime/harness/stages/*/contracts/interaction.contract.yaml)",
      "Edit(harness-runtime/harness/stages/*/contracts/interaction.contract.yaml)",
      "Write(harness-runtime/harness/stages/*/solution.md)",
      "Edit(harness-runtime/harness/stages/*/solution.md)",
      "Write(harness-runtime/harness/stages/*/tech-design.md)",
      "Edit(harness-runtime/harness/stages/*/tech-design.md)",
      "Write(harness-runtime/harness/stages/*/contracts/solution.contract.yaml)",
      "Write(harness-runtime/harness/stages/*/contracts/tech-design.contract.yaml)"
    ],
    "ask": [
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "allow": [
      "Write(harness-runtime/harness/stages/*/interaction.md)",
      "Write(harness-runtime/harness/stages/*/interaction-spec/**)",
      "Write(harness-runtime/harness/stages/*/visual-interaction/variants/**)",
      "Write(harness-runtime/harness/stages/*/visual-interaction/prototype/**)",
      "Write(harness-runtime/harness/stages/*/visual-interaction/evidence/**)",
      "Write(harness-runtime/harness/stages/*/visual-interaction/design-brief.md)",
      "Bash(harness *)"
    ]
  }
}
