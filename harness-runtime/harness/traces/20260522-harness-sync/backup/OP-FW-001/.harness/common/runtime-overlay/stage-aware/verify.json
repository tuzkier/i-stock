      "Edit(harness-runtime/harness/work-graph/**)",
      "Write(harness-runtime/harness/work-graph/**)",
      "Write(harness-runtime/harness/stages/*/contracts/verification-report.contract.yaml)",
      "Edit(harness-runtime/harness/stages/*/contracts/verification-report.contract.yaml)",
      "Edit(harness-runtime/config/harness.yaml)",
      "Edit(harness-runtime/config/model-routing.yaml)"
    ],
    "allow": [
      "Write(harness-runtime/harness/stages/*/verification-report.md)",
      "Edit(harness-runtime/harness/stages/*/verification-report.md)",
      "Bash(harness *)"
    ]
  }
}
