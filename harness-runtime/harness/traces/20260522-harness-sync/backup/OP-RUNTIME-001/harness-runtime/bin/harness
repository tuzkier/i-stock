#!/usr/bin/env python3
"""Installed Harness CLI shim."""

from __future__ import annotations

import runpy
import sys
from pathlib import Path


def resolve_cli() -> Path:
    shim = Path(__file__).resolve()
    workspace = shim.parents[2]
    installed = workspace / ".harness" / "common" / "cli" / "harness_cli.py"
    if installed.exists():
        return installed
    for source in (
        workspace / "package" / "common" / "cli" / "harness_cli.py",
        workspace / "common" / "cli" / "harness_cli.py",
    ):
        if source.exists():
            return source
    raise SystemExit("harness: cannot locate .harness/common/cli/harness_cli.py")


if __name__ == "__main__":
    cli = resolve_cli()
    sys.argv[0] = str(cli)
    runpy.run_path(str(cli), run_name="__main__")
